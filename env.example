#repeat-group: NEXTCLOUD suffix02 NEXTCLOUD_URL NEXTCLOUD_USER NEXTCLOUD_PW NEXTCLOUD_SYNC_FOLDERS NEXTCLOUD_TIMER NEXTCLOUD_CALENDAR
#required: Nextcloud base URL
NEXTCLOUD_URL=
#required: Nextcloud username
NEXTCLOUD_USER=
#required: Nextcloud app password
#secret
NEXTCLOUD_PW=
#repeat-optional-complete: NEXTCLOUD_SYNC_FOLDERS
#optional: CSV entries in REMOTE_PATH|LOCAL_PATH format; blank disables file sync
NEXTCLOUD_SYNC_FOLDERS=
#required: systemd sync interval; 0 disables automatic sync
#default-preset: 15m
NEXTCLOUD_TIMER=15m
#required: enable this account for /nextcloud calendar
#default-preset: 1
NEXTCLOUD_CALENDAR=1
