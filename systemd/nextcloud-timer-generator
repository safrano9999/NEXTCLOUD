#!/usr/bin/env python3
from __future__ import annotations

import os
import re
import sys
from pathlib import Path


def main() -> int:
    output = Path(sys.argv[1])
    wants = output / "timers.target.wants"
    wants.mkdir(parents=True, exist_ok=True)
    pattern = re.compile(r"^NEXTCLOUD_TIMER(?:_(\d+))?$")
    for key, interval in sorted(os.environ.items()):
        match = pattern.match(key)
        if not match or interval.strip().lower() in {"", "0", "false", "off", "none"}:
            continue
        index = str(int(match.group(1) or "1"))
        name = f"nextcloud-sync@{index}.timer"
        unit = output / name
        unit.write_text(
            "[Unit]\nDescription=Nextcloud account " + index + " synchronization timer\n\n"
            "[Timer]\nOnBootSec=2min\nOnUnitInactiveSec=" + interval.strip() + "\n"
            "Persistent=true\nUnit=nextcloud-sync@" + index + ".service\n\n"
            "[Install]\nWantedBy=timers.target\n",
            encoding="utf-8",
        )
        link = wants / name
        if not link.exists():
            link.symlink_to(Path("..") / name)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
